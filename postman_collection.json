{
    "info": {
        "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
        "name": "Remittance Platform",
        "description": "API collection for the Remittance Platform.\n\nServices:\n- **Orchestrator** (port 3000): Core transfer lifecycle\n- **FX Service** (port 3001): Foreign exchange quotes\n- **Payout Simulator** (port 3002): Payout partner simulation\n\nTypical flow: Create Transfer → Confirm → (Compliance review if needed) → Webhook (PAID/FAILED)",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "orchestrator_url",
            "value": "http://localhost:3000",
            "type": "string"
        },
        {
            "key": "fx_service_url",
            "value": "http://localhost:3001",
            "type": "string"
        },
        {
            "key": "payout_service_url",
            "value": "http://localhost:3002",
            "type": "string"
        },
        {
            "key": "transfer_id",
            "value": "",
            "type": "string"
        },
        {
            "key": "partner_payout_id",
            "value": "",
            "type": "string"
        },
        {
            "key": "webhook_secret",
            "value": "super-secret-webhook-key-change-me",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Orchestrator — Transfers",
            "description": "Core transfer lifecycle endpoints on the Orchestrator service.",
            "item": [
                {
                    "name": "Create Transfer",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "const res = pm.response.json();",
                                    "if (res.transferId) {",
                                    "    pm.collectionVariables.set('transfer_id', res.transferId);",
                                    "    console.log('Saved transfer_id:', res.transferId);",
                                    "}",
                                    "",
                                    "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                                    "pm.test('Transfer has QUOTED status', () => pm.expect(res.status).to.eql('QUOTED'));",
                                    "pm.test('Quote is present', () => pm.expect(res.quote).to.be.an('object'));"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"sender\": {\n        \"senderId\": \"sender-001\",\n        \"name\": \"Alice Johnson\"\n    },\n    \"recipient\": {\n        \"name\": \"Bob Williams\",\n        \"country\": \"US\",\n        \"payoutMethod\": \"BANK_TRANSFER\",\n        \"payoutDetails\": {\n            \"accountNumber\": \"123456789\",\n            \"routingNumber\": \"987654321\"\n        }\n    },\n    \"sendAmount\": 500,\n    \"sendCurrency\": \"USD\",\n    \"payoutCurrency\": \"EUR\"\n}"
                        },
                        "url": {
                            "raw": "{{orchestrator_url}}/transfers",
                            "host": [
                                "{{orchestrator_url}}"
                            ],
                            "path": [
                                "transfers"
                            ]
                        },
                        "description": "Creates a new transfer. Auto-fetches an FX quote and transitions to QUOTED status."
                    },
                    "response": []
                },
