        {
            "name": "Orchestrator — Compliance",
            "description": "Manual compliance review endpoints. Used when a transfer is in COMPLIANCE_PENDING status.",
            "item": [
                {
                    "name": "Approve Compliance",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "const res = pm.response.json();",
                                    "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                                    "pm.test('Status is PAYOUT_PENDING', () => pm.expect(res.status).to.eql('PAYOUT_PENDING'));"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"reviewerId\": \"reviewer-001\",\n    \"reason\": \"Verified identity and source of funds\"\n}"
                        },
                        "url": {
                            "raw": "{{orchestrator_url}}/transfers/{{transfer_id}}/compliance/approve",
                            "host": [
                                "{{orchestrator_url}}"
                            ],
                            "path": [
                                "transfers",
                                "{{transfer_id}}",
                                "compliance",
                                "approve"
                            ]
                        },
                        "description": "Manually approves a transfer in COMPLIANCE_PENDING. Initiates payout and transitions to PAYOUT_PENDING."
                    },
                    "response": []
                },
