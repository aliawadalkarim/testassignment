            ]
        },
        {
            "name": "Orchestrator — Webhooks",
            "description": "Webhook endpoint for payout status callbacks. Requires HMAC signature in the X-Webhook-Signature header.",
            "item": [
                {
                    "name": "Payout Status — PAID",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "const body = JSON.stringify({",
                                    "    partnerPayoutId: pm.collectionVariables.get('partner_payout_id') || 'PP-001',",
                                    "    transferId: pm.collectionVariables.get('transfer_id'),",
                                    "    status: 'PAID',",
                                    "    amount: 452.30,",
                                    "    currency: 'EUR',",
                                    "    timestamp: new Date().toISOString()",
                                    "});",
                                    "",
                                    "const secret = pm.collectionVariables.get('webhook_secret');",
                                    "const signature = CryptoJS.HmacSHA256(body, secret).toString(CryptoJS.enc.Hex);",
                                    "",
                                    "pm.request.headers.add({ key: 'X-Webhook-Signature', value: signature });",
                                    "pm.request.body.raw = body;"
                                ]
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                                    "const res = pm.response.json();",
                                    "pm.test('Transfer marked as PAID', () => pm.expect(res.status).to.eql('PAID'));"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"partnerPayoutId\": \"{{partner_payout_id}}\",\n    \"transferId\": \"{{transfer_id}}\",\n    \"status\": \"PAID\",\n    \"amount\": 452.30,\n    \"currency\": \"EUR\",\n    \"timestamp\": \"2026-01-01T00:00:00.000Z\"\n}"
                        },
                        "url": {
                            "raw": "{{orchestrator_url}}/webhooks/payout-status",
                            "host": [
                                "{{orchestrator_url}}"
                            ],
                            "path": [
                                "webhooks",
                                "payout-status"
                            ]
                        },
                        "description": "Simulates a PAID webhook from the payout partner. The pre-request script auto-generates the HMAC signature.\n\n**Note:** If running manually, set `partner_payout_id` and `transfer_id` collection variables first."
                    },
                    "response": []
                },
                {
                    "name": "Payout Status — FAILED",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "const body = JSON.stringify({",
                                    "    partnerPayoutId: pm.collectionVariables.get('partner_payout_id') || 'PP-001',",
                                    "    transferId: pm.collectionVariables.get('transfer_id'),",
                                    "    status: 'FAILED',",
                                    "    amount: 452.30,",
                                    "    currency: 'EUR',",
                                    "    timestamp: new Date().toISOString()",
                                    "});",
                                    "",
                                    "const secret = pm.collectionVariables.get('webhook_secret');",
                                    "const signature = CryptoJS.HmacSHA256(body, secret).toString(CryptoJS.enc.Hex);",
                                    "",
                                    "pm.request.headers.add({ key: 'X-Webhook-Signature', value: signature });",
                                    "pm.request.body.raw = body;"
                                ]
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                                    "const res = pm.response.json();",
                                    "pm.test('Transfer marked as REFUNDED', () => pm.expect(res.status).to.eql('REFUNDED'));"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"partnerPayoutId\": \"{{partner_payout_id}}\",\n    \"transferId\": \"{{transfer_id}}\",\n    \"status\": \"FAILED\",\n    \"amount\": 452.30,\n    \"currency\": \"EUR\",\n    \"timestamp\": \"2026-01-01T00:00:00.000Z\"\n}"
                        },
                        "url": {
                            "raw": "{{orchestrator_url}}/webhooks/payout-status",
                            "host": [
                                "{{orchestrator_url}}"
                            ],
                            "path": [
                                "webhooks",
                                "payout-status"
                            ]
                        },
                        "description": "Simulates a FAILED webhook. The transfer auto-transitions to REFUNDED."
                    },
                    "response": []
                }
            ]
        },
