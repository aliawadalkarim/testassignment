                            "host": [
                                "{{orchestrator_url}}"
                            ],
                            "path": [
                                "transfers",
                                "{{transfer_id}}",
                                "compliance",
                                "reject"
                            ]
                        },
                        "description": "Manually rejects a transfer in COMPLIANCE_PENDING. Transitions to COMPLIANCE_REJECTED."
                    },
                    "response": []
