                    "name": "Confirm Transfer",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "const res = pm.response.json();",
                                    "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                                    "console.log('Transfer status after confirm:', res.status);"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [],
                        "url": {
                            "raw": "{{orchestrator_url}}/transfers/{{transfer_id}}/confirm",
                            "host": [
                                "{{orchestrator_url}}"
                            ],
                            "path": [
