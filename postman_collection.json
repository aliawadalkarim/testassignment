                    "name": "Reject Compliance",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "const res = pm.response.json();",
                                    "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                                    "pm.test('Status is COMPLIANCE_REJECTED', () => pm.expect(res.status).to.eql('COMPLIANCE_REJECTED'));"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
