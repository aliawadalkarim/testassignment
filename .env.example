# Remittance Platform — Environment Variables
# Copy this file to .env and update values as needed.

# Shared webhook secret (must match between orchestrator and payout-simulator)
WEBHOOK_SECRET=super-secret-webhook-key-change-me

# Orchestrator
PORT=3000
MONGO_URI=mongodb://localhost:27017/remittance
FX_SERVICE_URL=http://localhost:3001
PAYOUT_SERVICE_URL=http://localhost:3002

# FX Service
FX_SERVICE_PORT=3001

# Payout Simulator
PAYOUT_SERVICE_PORT=3002
ORCHESTRATOR_WEBHOOK_URL=http://localhost:3000/webhooks/payout-status
